ts","label.admin.settings.scorecard.issue_type":"Issue Type","label.admin.settings.scorecard.edit_weights_description":"Set percentage weight for each issue type. The total weight must equal 100%.","label.admin.settings.scorecard.reset_to_defaults":"Reset to Defaults","label.admin.settings.enableCourseScoringInterface":"Enable Course Scoring Interface","label.admin.settings.scoreUnusedContent":"Score unused content and files","label.admin.settings.scoreUnpublishedContent":"Score unpublished content and files","label.admin.settings.tabs.student_access":"Student Access","student_access.settings.title":"Student Access Settings","student_access.settings.description":"Set the default options for all courses in your institution. Instructors can override these settings at the course level.","student_access.settings.user_guide_link":"Learn more about configuring Student Access Settings in the <a href=\'https://cidilabs.instructure.com/courses/6621/pages/udoit-admin-settings?module_item_id=360073\' target=\'_blank\' rel=\'noopener\'>UDOIT User Guide</a>.","student_access.settings.enable_feature":"Enable Student Access to Alternate Formats for this Institution","student_access.settings.enable_feature.annotation":"<b>Note:</b> This feature only works when the <a href=\\"https://udoit3.ciditools.com/student/setup\\">Canvas Theme Javascript</a> is installed.","student_access.settings.default_settings":"Student Access Defaults","student_access.settings.default_settings.subheading":"Instructors can override these settings at the course level.","student_access.settings.default_access":"Students can access alternate formats by default","student_access.settings.allow_requests":"Students can request alternate formats by default","student_access.settings.allow_requests.annotation":"Student Access features rely on the Cidiscape Task Runner. If it isn’t installed, you’ll need to install Cidiscape to enable this feature. <a href=\'https://cidilabs.com/support/\' target=\'_blank\'>Get installation help</a>","student_access.reset.success":"Successfully reset course defaults","student_access.reset.error":"Failed to reset course defaults","student_access.reset.title":"Reset Course Defaults","student_access.reset.description":"Restore all courses to the defaults set on this page. This will override any course-level settings that were made previously.","student_access.reset.button":"Reset All Course Defaults","student_access.reset.spinner":"Course Defaults Resetting...","student_access.reset.modal.title":"Are you sure you want to reset all course defaults?","student_access.reset.modal.description":"This will reset all course defaults to the settings you have set here.","student_access.reset.modal.button":"Reset Course Defaults","student_access.reset.modal.label":"A confirmation modal for resetting course defaults","label.admin.refresh_courses":"Refresh","label.admin.refresh_users":"Refresh","label.admin.task_data.tooltip":"This count includes all UDOIT Admin scans in the queue for your institution.","label.admin.task_data.scans_remaining":"{{count}} scans remaining","label.admin.task_data.toggle_tooltip":"Toggle Tooltip","bulkScan.button.title":"Rescan Courses ({{courseCount}})","bulkScan.modal.title":"Bulk Scan","bulkScan.modal.header":"{{courseCount}} courses selected for scanning","bulkScan.modal.subheader":"This number is based on currently selected filters","bulkScan.modal.skip_notice":"Please note, this scan will skip:","bulkScan.modal.skip_item.no_access":"courses to which you do not have access","bulkScan.modal.skip_item.recent_scan":"courses that have been scanned in the last 24 hours","bulkScan.modal.scan_description":"By default, we will only scan course content that has changed since the last scan. However, you can opt for a full rescan of all content. This option will take longer.","bulkScan.modal.full_rescan_checkbox":"Perform a full rescan","bulkScan.modal.button.close":"Close","bulkScan.modal.button.submit":"Submit","bulkScan.modal.label":